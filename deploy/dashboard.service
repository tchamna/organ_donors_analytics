[Unit]
Description=Organ Donor Analytics Dash Dashboard
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/opt/organ_donors_analytics
Environment=PROJECT_ROOT=/opt/organ_donors_analytics
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/organ_donors_analytics/.venv/bin/gunicorn -w 2 -b 127.0.0.1:8050 scripts.dash_dashboard:server
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
